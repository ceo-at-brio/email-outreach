# Copy this file to ".env" in the same folder and fill in your values.
# .env is gitignored — never commit it.

# Google AI Studio → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Apollo.io → Settings → Integrations → API
APOLLO_API_KEY=

# The exact email address of the Apollo inbox to send outreach from
SENDER_EMAIL=

# SerpAPI (optional — only needed for google-leads.py)
# https://serpapi.com/dashboard
SERPAPI_KEY=
